{:paths ["src"]
 ;; kotoba-lang/wit — Layer 2 (cap/effect) of the kotoba foundational stdlib.
 ;; WIT interface as EDN + capability-token data model. The user-facing face of
 ;; the existing deny-by-default effects.rs/policy.rs boundary — invents no new
 ;; enforcement gate. Zero third-party runtime deps; .cljc.
 ;; See ADR-kotoba-lang-foundational-stdlib.md.
 :deps {}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}}}
